{
  "installCommand": "mkdir -p bin && curl -fsSL -o /tmp/mdbook.tar.gz https://sourceforge.net/projects/mdbook.mirror/files/v0.5.2/mdbook-v0.5.2-x86_64-unknown-linux-gnu.tar.gz/download && tar -xzf /tmp/mdbook.tar.gz -C bin",
  "buildCommand": "./bin/mdbook build docs",
  "outputDirectory": "docs/book"
}
